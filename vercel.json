{
  "routes": [
    {
      "src": "^/products$",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/products/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "^/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}